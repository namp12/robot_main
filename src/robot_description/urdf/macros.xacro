<?xml version="1.0"?>
<!--
  macros.xacro - Reusable Xacro macros for robot components.

  Macros defined:
    1. drive_wheel   - A drive wheel with continuous joint (for odometry)
    2. caster_wheel  - A passive caster wheel (fixed or ball joint)
    3. encoder       - An encoder mounted on a wheel axis
    4. inertial_cylinder - Helper for cylinder inertia

  Usage:
    Included by robot.urdf.xacro. Call with:
      <xacro:drive_wheel prefix="left" x="0" y="0.15" .../>
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============= Inertia helpers ======================== -->
  <!-- Cylinder inertia (aligned along Z axis) -->
  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        ixy="0" ixz="0"
        iyy="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        iyz="0"
        izz="${(1.0/2.0) * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <!-- Box inertia -->
  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (y*y + z*z)}"
        ixy="0" ixz="0"
        iyy="${(1.0/12.0) * mass * (x*x + z*z)}"
        iyz="0"
        izz="${(1.0/12.0) * mass * (x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <!-- Sphere inertia -->
  <xacro:macro name="sphere_inertia" params="mass radius">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(2.0/5.0) * mass * radius * radius}"
        ixy="0" ixz="0"
        iyy="${(2.0/5.0) * mass * radius * radius}"
        iyz="0"
        izz="${(2.0/5.0) * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <!-- ============= Drive Wheel Macro ====================== -->
  <!--
    Creates a drive wheel link + continuous joint.
    The continuous joint allows rotation (needed for odometry).

    Parameters:
      prefix    : "left" or "right"
      wheel_radius : wheel radius in meters
      wheel_width  : wheel thickness in meters
      wheel_mass   : wheel mass in kg
      x_offset     : X position relative to base_link center
      y_offset     : Y position relative to base_link center
      z_offset     : Z position relative to base_link center
  -->
  <xacro:macro name="drive_wheel" params="prefix wheel_radius wheel_width wheel_mass x_offset y_offset z_offset">

    <!-- Wheel link -->
    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_gray"/>
        <!-- Rotate cylinder to align with Y axis (wheel orientation) -->
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <xacro:cylinder_inertia mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}"/>
    </link>

    <!-- Continuous joint: wheel can rotate freely -->
    <!-- When ESP32 provides odometry, this joint receives /joint_states -->
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel"/>
      <origin xyz="${x_offset} ${y_offset} ${z_offset}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <!-- Friction for Gazebo simulation -->
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

  </xacro:macro>

  <!-- ============= Caster Wheel Macro ===================== -->
  <!--
    Creates a passive caster wheel (sphere) at the rear.
    Uses a fixed joint (no actuation, just for physical support).

    Parameters:
      prefix        : "front" or "rear"
      caster_radius : caster ball radius in meters
      caster_mass   : caster mass in kg
      x_offset      : X position relative to base_link
      y_offset      : Y position relative to base_link
      z_offset      : Z position relative to base_link
  -->
  <xacro:macro name="caster_wheel" params="prefix caster_radius caster_mass x_offset y_offset z_offset">

    <link name="${prefix}_caster_wheel">
      <visual>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="caster_bronze"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
      <xacro:sphere_inertia mass="${caster_mass}" radius="${caster_radius}"/>
    </link>

    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${prefix}_caster_wheel"/>
      <origin xyz="${x_offset} ${y_offset} ${z_offset}" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

  <!-- ============= Encoder Macro ========================== -->
  <!--
    Creates an encoder link attached to the wheel axis.
    The encoder itself doesn't rotate; it's mounted on the chassis
    and reads the wheel's rotation.

    Parameters:
      prefix    : "left" or "right"
      enc_x, enc_y, enc_z : dimensions of encoder box
      enc_mass  : encoder mass
      x_offset  : position relative to base_link
      y_offset  : position relative to base_link
      z_offset  : position relative to base_link
  -->
  <xacro:macro name="encoder" params="prefix enc_x enc_y enc_z enc_mass x_offset y_offset z_offset">

    <link name="${prefix}_encoder">
      <visual>
        <geometry>
          <box size="${enc_x} ${enc_y} ${enc_z}"/>
        </geometry>
        <material name="encoder_yellow"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <box size="${enc_x} ${enc_y} ${enc_z}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
      <xacro:box_inertia mass="${enc_mass}" x="${enc_x}" y="${enc_y}" z="${enc_z}"/>
    </link>

    <joint name="${prefix}_encoder_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${prefix}_encoder"/>
      <origin xyz="${x_offset} ${y_offset} ${z_offset}" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>
